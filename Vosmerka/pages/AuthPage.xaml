<Page x:Class="Vosmerka.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Vosmerka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPage">

    <Grid>
        <Button x:Name="LoginButton" Content="Button" HorizontalAlignment="Left" Margin="400,355,0,0" VerticalAlignment="Top" Click="LoginButton_Click"/>
        <TextBox x:Name="LoginTextBox" HorizontalAlignment="Left" Margin="400,225,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <PasswordBox x:Name="PassBox" HorizontalAlignment="Left" Margin="400,263,0,0" VerticalAlignment="Top" Width="120"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="685,49,0,0" VerticalAlignment="Top" Click="ProductsButton_Click"/>

    </Grid>
</Page>
