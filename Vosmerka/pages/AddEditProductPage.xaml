<Page x:Class="Vosmerka.Pages.AddEditProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Vosmerka.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddEditProductPage">

    <StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Название:"/>
            <TextBox x:Name="NameTextBox" Width="200" Text="{Binding ProductName}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Артикул:"/>
            <TextBox x:Name="ArticleTextBox" Width="200" Text="{Binding Article}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Цена:"/>
            <TextBox x:Name="MinCostTextBox" Width="200" Text="{Binding MinCost}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Путь к картинке:"/>
            <TextBox x:Name="ImageTextBox" Width="200" Text="{Binding Image}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Тип продукта:"/>
            <ComboBox x:Name="ProductTypeComboBox" SelectedItem="{Binding ProductType}"
                      DisplayMemberPath="ProductTypeName" Width="200"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Сколько сотрудников необходимо:"/>
            <TextBox x:Name="HumanTextBox" Width="200" Text="{Binding HumanResourses}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Номер цеха:"/>
            <TextBox x:Name="ProductPlaseTextBox" Width="200" Text="{Binding ProductPlaseId}"/>
        </StackPanel>

        <Button x:Name="SaveButton" Content="Сохранить" Click="SaveButton_Click"/>
    </StackPanel>
</Page>
