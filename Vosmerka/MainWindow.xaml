<Window x:Class="Vosmerka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vosmerka"
        mc:Ignorable="d"
        Title="Восьмерка" Height="450" Width="800">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Image Source="/Images/Восьмерка.ico" 
               Grid.Row="0" HorizontalAlignment="Left"/>
            <Button Content="Назад" 
                Grid.Row="0" HorizontalAlignment="Right" 
                Click="BackButton_Click"/>
            <Frame x:Name="MainFrame" 
               Grid.Row="1" Source="Pages/AuthPage.xaml" 
               NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
