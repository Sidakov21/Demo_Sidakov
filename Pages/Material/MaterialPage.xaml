<Page x:Class="KruzhokDemkaV2.Pages.Material.MaterialPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KruzhokDemkaV2.Pages.Material"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MaterialPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox Grid.Row="1" x:Name="ProductsListBox" 
          HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="1" Margin="10">
                            <TextBlock>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} | {1}">
                                        <Binding Path="ProductType.Name"/>
                                        <Binding Path="Name"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="{Binding Article}"/>
                            <TextBlock Text="{Binding Materials, StringFormat=Материалы: {0}}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding MinCost}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsGreatThen10K}" Value="True">
                            <Setter Property="Background" Value="#BB5FCA"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>


        <StackPanel x:Name="MaterialsPanel" Grid.Row="2">
            <StackPanel x:Name="EditButtonsPanel">
                <Button x:Name="AddProductButton" Content="Добавить"/>
                <Button x:Name="EditProductButton" Content="Редактировать"/>
                <Button x:Name="DeleteProductButton" Content="Удалить"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Page>
