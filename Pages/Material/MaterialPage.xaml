<Page x:Class="KruzhokDemkaV2.Pages.Material.MaterialPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KruzhokDemkaV2.Pages.Material"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MaterialPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Список материалов -->
        <ListBox Grid.Row="0" x:Name="MaterialsListBox" 
                 HorizontalContentAlignment="Stretch"
                 Margin="5">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock FontWeight="Bold" FontSize="14">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} | {1}">
                                            <Binding Path="MaterialType.Name"/>
                                            <Binding Path="Name"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Text="Упаковка: " FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding QuantityInPackage}"/>
                                    <TextBlock Text=" " />
                                    <TextBlock Text="{Binding Unit.Name}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Остаток: " FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Stock}"/>
                                    <TextBlock Text=" " />
                                    <TextBlock Text="{Binding Unit.Name}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Мин. остаток: " FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding MinStock}"/>
                                    <TextBlock Text=" " />
                                    <TextBlock Text="{Binding Unit.Name}"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Cost, StringFormat=Стоимость: {0:C}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Stock}" Value="{Binding MinStock}">
                            <!-- Не сработает напрямую, используем конвертер или свойство в модели -->
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Нижняя панель с кнопками -->
        <StackPanel x:Name="BottomPanel" Grid.Row="1" Orientation="Horizontal" Margin="5">
            <StackPanel x:Name="EditButtonsPanel" Orientation="Horizontal">
                <Button x:Name="AddMaterialButton" Content="Добавить" Click="AddMaterialButton_Click" Margin="0,0,5,0"/>
                <Button x:Name="EditMaterialButton" Content="Редактировать" Click="EditMaterialButton_Click" Margin="0,0,5,0"/>
                <Button x:Name="DeleteMaterialButton" Content="Удалить" Click="DeleteMaterialButton_Click" Margin="0,0,5,0"/>
            </StackPanel>
            <Button x:Name="BackToProductsButton" Content="Назад к продукции" Click="BackToProductsButton_Click"/>
        </StackPanel>
    </Grid>
</Page>
